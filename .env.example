# Firebase project ID — used by firebase-admin for Firestore access.
GOOGLE_CLOUD_PROJECT=your-firebase-project-id

# Gemini API key — used server-side only (never exposed to the browser).
# Leave unset to use the deterministic rules engine fallback instead of Gemini.
GEMINI_API_KEY=your-gemini-api-key

# Set to "false" to use in-memory storage instead of Firestore (useful for local dev).
# USE_FIRESTORE=false
